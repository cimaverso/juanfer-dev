# ── Entorno virtual ──────────────────────────────────────
venv/
.venv/
env/
.env/

# ── Variables de entorno ──────────────────────────────────
.env
.env.local
.env.production
.env.*.local

# ── Python ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
*.manifest
*.spec

# ── pytest / coverage ─────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── mypy / ruff / linters ─────────────────────────────────
.mypy_cache/
.ruff_cache/

# ── Alembic ───────────────────────────────────────────────
# Mantener las migraciones, ignorar solo temporales
alembic/versions/*.pyc

# ── Archivos generados (PDFs, uploads) ───────────────────
media/
uploads/
static/pdfs/

# ── IDEs ──────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Logs ──────────────────────────────────────────────────
*.log
logs/

# ── Docker (opcional, si lo usas luego) ──────────────────
*.env.docker